{
  "manifest_version": 3,
  "name": "Brandivibe Maps Lead Scraper",
  "version": "1.6.0",
  "description": "Scrape Google Maps business listings into the Brandivibe sales brain. Premium WebGL aesthetic, real-time sync.",
  "author": "Brandivibe",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Brandivibe Maps Scraper",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://google.com/maps/*",
    "https://brandivibe.com/*",
    "https://countriesnow.space/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*",
        "https://google.com/maps/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
